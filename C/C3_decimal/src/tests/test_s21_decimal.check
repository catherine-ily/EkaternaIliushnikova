#test sub_overflow
s21_decimal a = {{0xFFFFFFFF, 0xFFFFFFFF, 0xFFFFFFFF, 0}};
s21_decimal b = {{0xFFFFFFFF, 0, 0, 0x80000000}}; 
s21_decimal result = {0};
int res = s21_sub(a, b, &result);
ck_assert_int_eq(res, 1); 

#test sub_underflow
s21_decimal a = {{0xFFFFFFFF, 0xFFFFFFFF, 0xFFFFFFFF, 0x80000000}};
s21_decimal b = {{0xFFFFFFFF, 0, 0, 0}};
s21_decimal result = {0};
int res = s21_sub(a, b, &result);
ck_assert_int_eq(res, 2); 


#test sub_carry_2

    
    s21_decimal c = {{0x00000000, 0x00000000, 0x00000001, 0}};
    s21_decimal d = {{0x00000001, 0x00000000, 0x00000000, 0}};
    s21_decimal result;
    int res = s21_sub(c, d, &result);
    
    
    ck_assert_int_eq(res, 0);
    ck_assert_int_eq((unsigned)result.bits[0], 0xFFFFFFFF);
    ck_assert_int_eq((unsigned)result.bits[1], 0xFFFFFFFF);
    ck_assert_int_eq(result.bits[2], 0x00000000);
    ck_assert_int_eq(result.bits[3], 0);


