#test negate_with_scale
s21_decimal value = {{123456, 0, 0, 0x30000}}; 
s21_decimal result;
int res = s21_negate(value, &result);
ck_assert_int_eq(res, 0);
ck_assert_int_eq(result.bits[0], 123456);
