#test round_negative_greater_than_half
s21_decimal value = {{123456, 0, 0, 0x80050000}}; 
s21_decimal result;
int res = s21_round(value, &result);
ck_assert_int_eq(res, 0);
ck_assert_int_eq(result.bits[0], 1); 
ck_assert_int_eq((result.bits[3] & (1u << 31)) != 0, 1);


