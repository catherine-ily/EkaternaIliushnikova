ck_assert_int_eq(res, 0);
ck_assert_int_eq(result.bits[0], 123);
ck_assert_int_eq(result.bits[3], 0);

#test floor_negative_integer
s21_decimal value = {{456, 0, 0, 0x80000000}};
s21_decimal result;
int res = s21_floor(value, &result);
ck_assert_int_eq(res, 0);
ck_assert_int_eq(result.bits[0], 456);
ck_assert_int_eq((result.bits[3] & (1u << 31)) != 0, 1);

#test floor_positive_with_fraction
