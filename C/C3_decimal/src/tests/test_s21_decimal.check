#test negate_small_positive
s21_decimal value = {{1, 0, 0, 0x1C0000}}; 
s21_decimal result;
int res = s21_negate(value, &result);
ck_assert_int_eq(res, 0);
ck_assert_int_eq(result.bits[0], 1);
ck_assert_int_eq((result.bits[3] & (1u << 31)) != 0, 1);

#test negate_small_negative
s21_decimal value = {{1, 0, 0, 0x801C0000}}; 
s21_decimal result;
int res = s21_negate(value, &result);
ck_assert_int_eq(res, 0);
ck_assert_int_eq(result.bits[0], 1);
ck_assert_int_eq((result.bits[3] & (1u << 31)) != 0, 0);

#test div_by_zero
s21_decimal value_1 = {{0, 0, 0, 0}};
s21_decimal value_2 = {{0, 0, 0, 0}};
s21_decimal result;
int status = s21_div(value_1, value_2, &result);
ck_assert_int_eq(status, 0);